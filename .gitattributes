# Set default behavior to automatically normalize line endings.
* text=auto

# Force batch scripts to always use CRLF line endings so that if a repo is accessed
# in Windows via cmd.exe, the scripts will work.
*.{cmd,[cC][mM][dD]} text eol=crlf

# Force bash scripts to always use LF line endings so that if a repo is accessed
# in Unix via sh, the scripts will work.
*.{sh} text eol=lf

# Markdown files should use LF
*.md text eol=lf

# JSON and YAML files should use LF
*.{json,yml,yaml} text eol=lf

# Denote all files that are truly binary and should not be modified.
*.{png,jpg,gif,ico,woff,woff2,ttf,eot} binary
